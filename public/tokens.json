{
  "$description": "Design System FlexiWeb — tokens v1.1 (arbitrés yg0a1n 2026-07-03 ; v1.1 2026-07-04 : +font.display, gaps theme.css comblés). Format DTCG-like.",
  "color": {
    "brand":        { "$type": "color", "$value": "#16a34a", "$description": "vert marque (logo)" },
    "brand-strong": { "$type": "color", "$value": "#0a5a28", "$description": "primary (boutons/actions)" },
    "brand-deep":   { "$type": "color", "$value": "#0c5526", "$description": "titres / heading" },
    "brand-accent": { "$type": "color", "$value": "#9acd32", "$description": "accent yellow-green" },
    "brand-accent-ink": { "$type": "color", "$value": "#6fa01f" },
    "accent-soft": { "$type": "color", "$value": "#d4ed9f", "$description": "tint pâle de brand-accent — FONDS de highlight/chips accent doux/bandeaux (jamais le texte)" },
    "surface": { "$type": "color", "$value": "#f6faf6" },
    "cream":   { "$type": "color", "$value": "#eef5ee" },
    "cream-deep": { "$type": "color", "$value": "#e3efe3", "$description": "cran vert plus soutenu sous sage-soft (fond de card/section vert renforcé, séparateur doux vert)" },
    "sage":    { "$type": "color", "$value": "#d7edda" },
    "sage-soft": { "$type": "color", "$value": "#e8f3ea", "$description": "vert doux — surface de card (pendant vert de sand)" },
    "sand":      { "$type": "color", "$value": "#f6eedf", "$description": "neutre chaud clair — surface de card + sections éditoriales" },
    "sand-deep": { "$type": "color", "$value": "#e8d8bc", "$description": "neutre chaud soutenu — surface de card + bordures/chips eyebrow/séparateurs" },
    "background": { "$type": "color", "$value": "#ffffff" },
    "foreground": { "$type": "color", "$value": "#1f2937" },
    "muted-foreground": { "$type": "color", "$value": "#4b5563" },
    "faint":   { "$type": "color", "$value": "#6b7280" },
    "border":  { "$type": "color", "$value": "#e2e8e4" },
    "border-strong": { "$type": "color", "$value": "#cbd5cf", "$description": "bordure d'emphase (vert-gris) — séparateur plus marqué que border" },
    "on-brand": { "$type": "color", "$value": "#ffffff" },
    "destructive": { "$type": "color", "$value": "#bf000f" }
  },
  "gradient": {
    "brand": { "$type": "gradient", "$value": "linear-gradient(135deg, #0c5526 0%, #0c5526 58%, #16a34a 80%, #9acd32 100%)" }
  },
  "font": {
    "sans":  { "$type": "fontFamily", "$value": "\"Hanken Grotesk\", ui-sans-serif, system-ui, sans-serif", "$description": "corps" },
    "serif": { "$type": "fontFamily", "$value": "\"Fraunces\", ui-serif, Georgia, serif", "$description": "titres / display" },
    "display": { "$type": "fontFamily", "$value": "\"Fraunces\", ui-serif, Georgia, serif", "$description": "slot display (alias de serif) — ajouté v1.1" },
    "mono":  { "$type": "fontFamily", "$value": "ui-monospace, SFMono-Regular, Menlo, Monaco, monospace" }
  },
  "fontSize": {
    "xs":  { "$type": "dimension", "$value": "0.75rem" },
    "sm":  { "$type": "dimension", "$value": "0.875rem" },
    "base":{ "$type": "dimension", "$value": "1rem" },
    "lg":  { "$type": "dimension", "$value": "1.125rem" },
    "xl":  { "$type": "dimension", "$value": "1.25rem" },
    "2xl": { "$type": "dimension", "$value": "1.5rem" },
    "3xl": { "$type": "dimension", "$value": "2.25rem" },
    "4xl": { "$type": "dimension", "$value": "3rem" },
    "5xl": { "$type": "dimension", "$value": "3.75rem" }
  },
  "fontWeight": {
    "normal":   { "$type": "fontWeight", "$value": 400 },
    "medium":   { "$type": "fontWeight", "$value": 500 },
    "semibold": { "$type": "fontWeight", "$value": 600 },
    "bold":     { "$type": "fontWeight", "$value": 700 }
  },
  "radius": {
    "sm":  { "$type": "dimension", "$value": "0.375rem" },
    "md":  { "$type": "dimension", "$value": "0.625rem", "$description": "défaut" },
    "lg":  { "$type": "dimension", "$value": "0.75rem" },
    "xl":  { "$type": "dimension", "$value": "1rem" },
    "2xl": { "$type": "dimension", "$value": "1.5rem" }
  },
  "shadow": {
    "sm": { "$type": "shadow", "$value": "0 1px 2px 0 rgba(0,0,0,0.05)" },
    "md": { "$type": "shadow", "$value": "0 1px 3px 0 rgba(0,0,0,0.1), 0 1px 2px -1px rgba(0,0,0,0.1)" }
  }
}

{
  "$description": "Design System FlexiWeb — tokens v1.1 (arbitrés yg0a1n 2026-07-03 ; v1.1 2026-07-04 : +font.display, gaps theme.css comblés). Format DTCG-like.",
  "color": {
    "brand":        { "$type": "color", "$value": "#16a34a", "$description": "vert marque (logo)" },
    "brand-strong": { "$type": "color", "$value": "#0a5a28", "$description": "primary (boutons/actions)" },
    "brand-deep":   { "$type": "color", "$value": "#0c5526", "$description": "titres / heading" },
    "brand-accent": { "$type": "color", "$value": "#9acd32", "$description": "accent yellow-green" },
    "brand-accent-ink": { "$type": "color", "$value": "#6fa01f" },
    "accent-soft": { "$type": "color", "$value": "#d4ed9f", "$description": "tint pâle de brand-accent — FONDS de highlight/chips accent doux/bandeaux (jamais le texte)" },
    "surface": { "$type": "color", "$value": "#f6faf6" },
    "cream":   { "$type": "color", "$value": "#eef5ee" },
    "cream-deep": { "$type": "color", "$value": "#e3efe3", "$description": "cran vert plus soutenu sous sage-soft (fond de card/section vert renforcé, séparateur doux vert)" },
    "sage":    { "$type": "color", "$value": "#d7edda" },
    "sage-soft": { "$type": "color", "$value": "#e8f3ea", "$description": "vert doux — surface de card (pendant vert de sand)" },
    "sand":      { "$type": "color", "$value": "#f6eedf", "$description": "neutre chaud clair — surface de card + sections éditoriales" },
    "sand-deep": { "$type": "color", "$value": "#e8d8bc", "$description": "neutre chaud soutenu — surface de card + bordures/chips eyebrow/séparateurs" },
    "background": { "$type": "color", "$value": "#ffffff" },
    "foreground": { "$type": "color", "$value": "#1f2937" },
    "muted-foreground": { "$type": "color", "$value": "#4b5563" },
    "faint":   { "$type": "color", "$value": "#6b7280" },
    "border":  { "$type": "color", "$value": "#e2e8e4" },
    "border-strong": { "$type": "color", "$value": "#cbd5cf", "$description": "bordure d'emphase (vert-gris) — séparateur plus marqué que border" },
    "on-brand": { "$type": "color", "$value": "#ffffff" },
    "destructive": { "$type": "color", "$value": "#bf000f" },
    "success": { "$type": "color", "$value": "#047857", "$description": "état SUCCÈS — émeraude foncé, DISTINCT du vert de marque #16a34a (hue 163 vs 142, +froid, +foncé). Fond badge/toast (fg blanc) ou texte sur clair. AA 5.5:1 (Lot 3 #12)" },
    "warning": { "$type": "color", "$value": "#b45309", "$description": "état ALERTE — ambre/ochre foncé. Fond badge/toast (fg blanc) ou texte sur clair. AA 5.0:1 (Lot 3 #12)" },
    "info":    { "$type": "color", "$value": "#1d4ed8", "$description": "état INFO — bleu foncé. Fond badge/toast (fg blanc) ou texte sur clair. AA 6.7:1 (Lot 3 #12)" }
  },
  "semantic": {
    "$description": "Couche shadcn — ALIAS DÉRIVÉS des primitives color.* (Lot 1 #8, réconciliation distribution). Zéro valeur ré-arbitrée : chaque alias résout au MÊME hex que theme.css/registry. background/foreground/muted-foreground/destructive restent des primitives dans color.*.",
    "card":                  { "$type": "color", "$value": "{color.background}" },
    "card-foreground":       { "$type": "color", "$value": "{color.foreground}" },
    "popover":               { "$type": "color", "$value": "{color.background}" },
    "popover-foreground":    { "$type": "color", "$value": "{color.foreground}" },
    "primary":               { "$type": "color", "$value": "{color.brand-strong}", "$description": "primary = brand-strong" },
    "primary-foreground":    { "$type": "color", "$value": "{color.on-brand}" },
    "secondary":             { "$type": "color", "$value": "{color.surface}" },
    "secondary-foreground":  { "$type": "color", "$value": "{color.brand-deep}" },
    "muted":                 { "$type": "color", "$value": "{color.surface}" },
    "accent":                { "$type": "color", "$value": "{color.cream}" },
    "accent-foreground":     { "$type": "color", "$value": "{color.brand-deep}" },
    "destructive-foreground":{ "$type": "color", "$value": "{color.on-brand}" },
    "input":                 { "$type": "color", "$value": "{color.border}" },
    "ring":                  { "$type": "color", "$value": "{color.brand}", "$description": "focus ring défaut (surfaces claires)" },
    "ring-strong":           { "$type": "color", "$value": "{color.brand-deep}", "$description": "focus ring surfaces teintées (cards) — a11y Lot 1 #8" },
    "ring-offset":           { "$type": "color", "$value": "{color.background}", "$description": "halo ring-offset (pattern shadcn)" },
    "heading":               { "$type": "color", "$value": "{color.brand-deep}", "$description": "heading = brand-deep" },
    "chart-1":               { "$type": "color", "$value": "{color.brand}" },
    "chart-2":               { "$type": "color", "$value": "{color.brand-strong}" },
    "chart-3":               { "$type": "color", "$value": "{color.brand-accent}" },
    "chart-4":               { "$type": "color", "$value": "{color.brand-accent-ink}" },
    "chart-5":               { "$type": "color", "$value": "{color.muted-foreground}" },
    "success-foreground":    { "$type": "color", "$value": "{color.on-brand}", "$description": "texte sur --success (blanc) — Lot 3 #12" },
    "warning-foreground":    { "$type": "color", "$value": "{color.on-brand}", "$description": "texte sur --warning (blanc)" },
    "info-foreground":       { "$type": "color", "$value": "{color.on-brand}", "$description": "texte sur --info (blanc)" }
  },
  "dark": {
    "$description": "Palette DARK (Lot 5/5b #16/#18) — miroir STRICT de theme.css .dark / registry cssVars.dark. Thème override (pas des primitives light). Valeurs déjà arbitrées yg0a1n (aperçu). 0 nouvelle valeur.",
    "background": { "$type": "color", "$value": "#0b1510" },
    "foreground": { "$type": "color", "$value": "#e7f0ea" },
    "card": { "$type": "color", "$value": "#111d16" },
    "card-foreground": { "$type": "color", "$value": "#e7f0ea" },
    "popover": { "$type": "color", "$value": "#111d16" },
    "popover-foreground": { "$type": "color", "$value": "#e7f0ea" },
    "primary": { "$type": "color", "$value": "#22c55e" },
    "primary-foreground": { "$type": "color", "$value": "#06120b" },
    "secondary": { "$type": "color", "$value": "#16241c" },
    "secondary-foreground": { "$type": "color", "$value": "#e7f0ea" },
    "muted": { "$type": "color", "$value": "#16241c" },
    "muted-foreground": { "$type": "color", "$value": "#9db0a5" },
    "accent": { "$type": "color", "$value": "#1c2e24" },
    "accent-foreground": { "$type": "color", "$value": "#e7f0ea" },
    "destructive": { "$type": "color", "$value": "#f87171" },
    "destructive-foreground": { "$type": "color", "$value": "#06120b" },
    "success": { "$type": "color", "$value": "#34d399" },
    "success-foreground": { "$type": "color", "$value": "#06120b" },
    "warning": { "$type": "color", "$value": "#fbbf24" },
    "warning-foreground": { "$type": "color", "$value": "#06120b" },
    "info": { "$type": "color", "$value": "#60a5fa" },
    "info-foreground": { "$type": "color", "$value": "#06120b" },
    "border": { "$type": "color", "$value": "#24352b" },
    "border-strong": { "$type": "color", "$value": "#33463a" },
    "input": { "$type": "color", "$value": "#24352b" },
    "ring": { "$type": "color", "$value": "#4ade80" },
    "ring-strong": { "$type": "color", "$value": "#4ade80" },
    "ring-offset": { "$type": "color", "$value": "#0b1510" },
    "brand": { "$type": "color", "$value": "#4ade80" },
    "brand-strong": { "$type": "color", "$value": "#22c55e" },
    "brand-deep": { "$type": "color", "$value": "#16a34a" },
    "brand-accent": { "$type": "color", "$value": "#a3e635" },
    "brand-accent-ink": { "$type": "color", "$value": "#84cc16" },
    "accent-soft": { "$type": "color", "$value": "#14532d" },
    "on-brand": { "$type": "color", "$value": "#06120b" },
    "heading": { "$type": "color", "$value": "#e7f0ea" },
    "faint": { "$type": "color", "$value": "#8a978f" },
    "surface": { "$type": "color", "$value": "#101a14" },
    "cream": { "$type": "color", "$value": "#111d16" },
    "cream-deep": { "$type": "color", "$value": "#16241c" },
    "sage": { "$type": "color", "$value": "#1c2e24" },
    "sage-soft": { "$type": "color", "$value": "#16241c" },
    "sand": { "$type": "color", "$value": "#1f1b12" },
    "sand-deep": { "$type": "color", "$value": "#2a2416" },
    "chart-1": { "$type": "color", "$value": "#4ade80" },
    "chart-2": { "$type": "color", "$value": "#22c55e" },
    "chart-3": { "$type": "color", "$value": "#a3e635" },
    "chart-4": { "$type": "color", "$value": "#84cc16" },
    "chart-5": { "$type": "color", "$value": "#9db0a5" }
  },
  "gradient": {
    "brand": { "$type": "gradient", "$value": "linear-gradient(135deg, #0c5526 0%, #0c5526 58%, #16a34a 80%, #9acd32 100%)" }
  },
  "font": {
    "sans":  { "$type": "fontFamily", "$value": "\"Hanken Grotesk\", ui-sans-serif, system-ui, sans-serif", "$description": "corps" },
    "serif": { "$type": "fontFamily", "$value": "\"Fraunces\", ui-serif, Georgia, serif", "$description": "titres / display" },
    "display": { "$type": "fontFamily", "$value": "\"Fraunces\", ui-serif, Georgia, serif", "$description": "slot display (alias de serif) — ajouté v1.1" },
    "mono":  { "$type": "fontFamily", "$value": "ui-monospace, SFMono-Regular, Menlo, Monaco, monospace" }
  },
  "fontSize": {
    "xs":  { "$type": "dimension", "$value": "0.75rem" },
    "sm":  { "$type": "dimension", "$value": "0.875rem" },
    "base":{ "$type": "dimension", "$value": "1rem" },
    "lg":  { "$type": "dimension", "$value": "1.125rem" },
    "xl":  { "$type": "dimension", "$value": "1.25rem" },
    "2xl": { "$type": "dimension", "$value": "1.5rem" },
    "3xl": { "$type": "dimension", "$value": "2.25rem" },
    "4xl": { "$type": "dimension", "$value": "3rem" },
    "5xl": { "$type": "dimension", "$value": "3.75rem" }
  },
  "fontWeight": {
    "normal":   { "$type": "fontWeight", "$value": 400 },
    "medium":   { "$type": "fontWeight", "$value": 500 },
    "semibold": { "$type": "fontWeight", "$value": 600 },
    "bold":     { "$type": "fontWeight", "$value": 700 }
  },
  "lineHeight": {
    "$description": "Échelle line-height (Lot 4 #14) → utilitaires leading-*. tight=titres display Fraunces, normal=corps.",
    "tight":   { "$type": "number", "$value": 1.1,  "$description": "titres display (Fraunces)" },
    "snug":    { "$type": "number", "$value": 1.3,  "$description": "sous-titres / headings" },
    "normal":  { "$type": "number", "$value": 1.5,  "$description": "corps (défaut)" },
    "relaxed": { "$type": "number", "$value": 1.7,  "$description": "texte long / lisibilité" }
  },
  "letterSpacing": {
    "$description": "Échelle letter-spacing (Lot 4 #14) → utilitaires tracking-*. Grounded sur l'usage diag/landing (eyebrows uppercase = wide 0.08em).",
    "tighter": { "$type": "dimension", "$value": "-0.02em", "$description": "grand display" },
    "tight":   { "$type": "dimension", "$value": "-0.01em", "$description": "titres" },
    "normal":  { "$type": "dimension", "$value": "0em",     "$description": "corps" },
    "wide":    { "$type": "dimension", "$value": "0.08em",  "$description": "eyebrows uppercase (usage diag)" },
    "wider":   { "$type": "dimension", "$value": "0.14em",  "$description": "labels all-caps" }
  },
  "radius": {
    "sm":  { "$type": "dimension", "$value": "0.375rem" },
    "md":  { "$type": "dimension", "$value": "0.625rem", "$description": "défaut" },
    "lg":  { "$type": "dimension", "$value": "0.75rem" },
    "xl":  { "$type": "dimension", "$value": "1rem" },
    "2xl": { "$type": "dimension", "$value": "1.5rem" }
  },
  "spacing": {
    "$description": "Échelle d'espacement (Lot 2 #10). FORME = base multiplicative Tailwind v4 : --spacing = 0.25rem (4px) génère TOUS les utilitaires p-*/m-*/gap-*/space-* (p-1=4px … p-4=16px … p-24=96px), zéro vocabulaire parallèle à maintenir. RYTHME recommandé du DS (multiples de 4, harmonisé au pas radius 16/24px) : 2xs 4px(p-1) · xs 8px(p-2) · sm 12px(p-3) · md 16px(p-4, padding card) · lg 24px(p-6, gap section) · xl 32px(p-8) · 2xl 48px(p-12, section vertical mobile) · 3xl 64px(p-16, section vertical desktop) · 4xl 96px(p-24, respiration hero).",
    "base": { "$type": "dimension", "$value": "0.25rem", "$description": "unité Tailwind v4 (--spacing) — multiplicateur de p-N/m-N/gap-N" }
  },
  "shadow": {
    "$description": "Échelle d'ombres (Lot 4 #14) — undertone noir faible-opacité cohérent (hairline → overlay). sm/md existants (Lot 1).",
    "xs": { "$type": "shadow", "$value": "0 1px 1px 0 rgba(0,0,0,0.04)", "$description": "hairline (bordure subtile)" },
    "sm": { "$type": "shadow", "$value": "0 1px 2px 0 rgba(0,0,0,0.05)" },
    "md": { "$type": "shadow", "$value": "0 1px 3px 0 rgba(0,0,0,0.1), 0 1px 2px -1px rgba(0,0,0,0.1)" },
    "lg": { "$type": "shadow", "$value": "0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1)", "$description": "card élevée / dropdown" },
    "xl": { "$type": "shadow", "$value": "0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1)", "$description": "modale / overlay" }
  }
}
